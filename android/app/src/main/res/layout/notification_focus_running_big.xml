<?xml version="1.0" encoding="utf-8"?>
<!--
  إشعار جلسة التركيز (Live Activity) — العرض الموسّع.
  أرقام أكبر + اسم المهمة + رقم البومودورو + زر إيقاف.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="14dp">

    <!-- صف الأرقام + زر الإيقاف -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:layoutDirection="ltr"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvNotifMinTens"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_black"
                android:includeFontPadding="false"
                android:text="0"
                android:textColor="#9C5BE0"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNotifMinUnits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_black"
                android:includeFontPadding="false"
                android:text="0"
                android:textColor="#E8607E"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNotifColon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:fontFamily="@font/montserrat_black"
                android:includeFontPadding="false"
                android:text=":"
                android:textColor="@android:color/white"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNotifSecTens"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_black"
                android:includeFontPadding="false"
                android:text="0"
                android:textColor="#9C5BE0"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNotifSecUnits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_black"
                android:includeFontPadding="false"
                android:text="0"
                android:textColor="#E8607E"
                android:textSize="46sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnNotifStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_notif_stop_btn"
            android:fontFamily="@font/raleway_family"
            android:paddingStart="18dp"
            android:paddingTop="9dp"
            android:paddingEnd="18dp"
            android:paddingBottom="9dp"
            android:text="إيقاف"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- معلومات الجلسة (اسم المهمة + الطمطم) -->
    <TextView
        android:id="@+id/tvNotifTaskInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/raleway_family"
        android:gravity="start"
        android:text="🍅 1 • تركيز"
        android:textAlignment="viewStart"
        android:textColor="#CCCCCC"
        android:textDirection="rtl"
        android:textSize="13sp" />

</LinearLayout>
