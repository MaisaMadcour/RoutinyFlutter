<?xml version="1.0" encoding="utf-8"?>
<!--
  إشعار جلسة التركيز (Live Activity) — العرض المختصر.
  بيظهر الأرقام الكبيرة بألوان التطبيق (بنفسجي + بينك) + زر إيقاف.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <!-- صف الأرقام الكبيرة -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:layoutDirection="ltr"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvNotifMinTens"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat_black"
            android:includeFontPadding="false"
            android:text="0"
            android:textColor="#9C5BE0"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotifMinUnits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat_black"
            android:includeFontPadding="false"
            android:text="0"
            android:textColor="#E8607E"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotifColon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:fontFamily="@font/montserrat_black"
            android:includeFontPadding="false"
            android:text=":"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotifSecTens"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat_black"
            android:includeFontPadding="false"
            android:text="0"
            android:textColor="#9C5BE0"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotifSecUnits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat_black"
            android:includeFontPadding="false"
            android:text="0"
            android:textColor="#E8607E"
            android:textSize="34sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- زر الإيقاف -->
    <TextView
        android:id="@+id/btnNotifStop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:background="@drawable/bg_notif_stop_btn"
        android:fontFamily="@font/raleway_family"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:text="إيقاف"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
